# Server Configuration
KEYWATCHER_PORT=8080
KEYWATCHER_LOG_LEVEL=info

# Database
KEYWATCHER_DB_URL=postgres://keywatcher:secret@localhost:5432/keywatcher?sslmode=disable

# Authentication Methods (comma-separated: local,oidc,ldap)
KEYWATCHER_AUTH_METHODS=local,oidc,ldap

# OIDC Configuration (if enabled)
KEYWATCHER_OIDC_ISSUER=https://accounts.example.com
KEYWATCHER_OIDC_CLIENT_ID=keywatcher
KEYWATCHER_OIDC_CLIENT_SECRET=secret

# LDAP Configuration (if enabled)
KEYWATCHER_LDAP_URL=ldap://ldap.example.com:389
KEYWATCHER_LDAP_BIND_DN=cn=keywatcher,dc=example,dc=com
KEYWATCHER_LDAP_BIND_PASSWORD=secret
KEYWATCHER_LDAP_BASE_DN=ou=users,dc=example,dc=com
KEYWATCHER_LDAP_USER_FILTER=(uid=%s)

# Expiry Checker Configuration
KEYWATCHER_CHECK_INTERVAL=1h
KEYWATCHER_WARN_DAYS=30,14,7,1

# Notification Webhooks (at least one required for alerts)
KEYWATCHER_NOTIFY_SLACK_WEBHOOK=https://hooks.slack.com/services/YOUR/WEBHOOK/HERE
KEYWATCHER_NOTIFY_MATTERMOST_WEBHOOK=https://mattermost.example.com/hooks/YOUR_WEBHOOK
KEYWATCHER_NOTIFY_GENERIC_WEBHOOK=https://my.webhook.example.com/alert

# Prometheus Metrics
KEYWATCHER_METRICS_PATH=/metrics
