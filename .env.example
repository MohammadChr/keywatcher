# Server Configuration
VAULTWATCH_PORT=8080
VAULTWATCH_LOG_LEVEL=info

# Database
VAULTWATCH_DB_URL=postgres://vaultwatch:secret@localhost:5432/vaultwatch?sslmode=disable

# Authentication Methods (comma-separated: local,oidc,ldap)
VAULTWATCH_AUTH_METHODS=local,oidc,ldap

# OIDC Configuration (if enabled)
VAULTWATCH_OIDC_ISSUER=https://accounts.example.com
VAULTWATCH_OIDC_CLIENT_ID=vaultwatch
VAULTWATCH_OIDC_CLIENT_SECRET=secret

# LDAP Configuration (if enabled)
VAULTWATCH_LDAP_URL=ldap://ldap.example.com:389
VAULTWATCH_LDAP_BIND_DN=cn=vaultwatch,dc=example,dc=com
VAULTWATCH_LDAP_BIND_PASSWORD=secret
VAULTWATCH_LDAP_BASE_DN=ou=users,dc=example,dc=com
VAULTWATCH_LDAP_USER_FILTER=(uid=%s)

# Expiry Checker Configuration
VAULTWATCH_CHECK_INTERVAL=1h
VAULTWATCH_WARN_DAYS=30,14,7,1

# Notification Webhooks (at least one required for alerts)
VAULTWATCH_NOTIFY_SLACK_WEBHOOK=https://hooks.slack.com/services/YOUR/WEBHOOK/HERE
VAULTWATCH_NOTIFY_MATTERMOST_WEBHOOK=https://mattermost.example.com/hooks/YOUR_WEBHOOK
VAULTWATCH_NOTIFY_GENERIC_WEBHOOK=https://my.webhook.example.com/alert

# Prometheus Metrics
VAULTWATCH_METRICS_PATH=/metrics
